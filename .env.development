# Dev proxy target for /api and /uploads (see vite.config.js).
# Must match PORT in server/.env
VITE_API_PORT=5002

# Dev: Download PDF uses server Puppeteer. Production (.env.production) uses browser Print → Save as PDF.
VITE_QUOTE_PDF_SERVER_DOWNLOAD=1
VITE_QUOTE_PDF_BROWSER_DOWNLOAD=0

# Optional: high-res ACG logo URL for header/login (PNG/SVG). Same in .env.production for IIS builds.
# VITE_ACG_LOGO_URL=/acg-header-logo@2x.png
